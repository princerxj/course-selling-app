# Database Configuration
DB_URL=mongodb://localhost:27017/course-selling-app

# JWT Secrets (Change these to strong random strings in production)
JWT_USER_PASSWORD=your_jwt_user_secret_key
JWT_ADMIN_PASSWORD=your_jwt_admin_secret_key

# Cloudinary Configuration (Image Upload Service)
CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret

# Server Configuration (Optional)
# PORT=3000
# NODE_ENV=development
